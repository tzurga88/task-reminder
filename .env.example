# Copier ce fichier en .env et remplir les valeurs

# Token du bot Telegram (obtenu via @BotFather sur Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Ton Chat ID Telegram (envoie /start au bot, puis va sur https://api.telegram.org/bot<TON_TOKEN>/getUpdates)
TELEGRAM_CHAT_ID=your_chat_id_here

# Port du serveur (Railway/Render l'assignent automatiquement)
PORT=3000

# Fuseau horaire pour les rappels (ex: Europe/Paris, America/Montreal)
TIMEZONE=Europe/Paris
